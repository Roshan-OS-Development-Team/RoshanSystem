<Window x:Class="Roshan_System.winver"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Roshan_System"
        mc:Ignorable="d"
        Title="winver" Height="400" Width="225">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black"/>
            <GradientStop Color="#FF1E1E1E" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>
    <Grid>
        <Rectangle HorizontalAlignment="Center" Height="3" Margin="0,118,0,0" Stroke="Black" VerticalAlignment="Top" Width="224" Fill="White"/>
        <Image HorizontalAlignment="Left" Height="50" Margin="20,45,0,0" VerticalAlignment="Top" Width="50" Source="/startmenu.png"/>
        <TextBlock HorizontalAlignment="Left" Margin="75,52,0,0" TextWrapping="Wrap" Text="Roshan OS" VerticalAlignment="Top" Height="36" Width="141" Foreground="White" FontSize="24" FontWeight="Bold"/>
        <TextBlock HorizontalAlignment="Left" Margin="10,139,0,0" TextWrapping="Wrap" Text="OS Version 6 (OS Build 6.2623)" VerticalAlignment="Top" Foreground="White" Width="166"/>
        <TextBlock HorizontalAlignment="Center" Margin="0,192,0,0" TextWrapping="Wrap" Text="The Roshan OS and its user interface is fully open-source for anyone to use" VerticalAlignment="Top" Foreground="White" Width="205"/>
        <TextBlock HorizontalAlignment="Center" Margin="0,265,0,0" TextWrapping="Wrap" Text="This product is made by Roshan" VerticalAlignment="Top" Foreground="White" Width="205"/>
        <Rectangle HorizontalAlignment="Center" Height="4" Margin="0,281,0,0" Stroke="Black" VerticalAlignment="Top" Width="226" Fill="White"/>
        <TextBlock HorizontalAlignment="Left" Margin="10,296,0,0" TextWrapping="Wrap" Text="Roshan The Modder" VerticalAlignment="Top" Foreground="White"/>
        <TextBlock HorizontalAlignment="Left" Margin="10,312,0,0" TextWrapping="Wrap" Text="Roshan Aerospace and Space Agency" VerticalAlignment="Top" Foreground="White"/>
        <Button Content="OK" HorizontalAlignment="Left" Margin="189,333,0,0" VerticalAlignment="Top" Background="{x:Null}" Foreground="White" FontWeight="Bold" Click="Close"/>

    </Grid>
</Window>
