<Window x:Class="Roshan_System.Overclocker"
        Icon="/textures/Overclocker.png"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Roshan_System"
        mc:Ignorable="d"
        Title="Overclocker" Height="200" Width="400">
    <Grid Background="Black">
        <Label x:Name="cslabel" Content="0.5" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#FF121212" Foreground="White" Height="164" Width="164" IsEnabled="False" FontSize="120"/>
        <Button Content="+&#xD;&#xA;" HorizontalAlignment="Left" Margin="287,0,0,0" VerticalAlignment="Center" Height="164" Width="103" Foreground="White" Background="#FF120F12" FontSize="144" Click="Add"/>
        <Button Content="-" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center" Height="164" Width="103" Background="#FF120F12" Foreground="White" IsCancel="True" FontSize="144" Click="Subtract"/>

    </Grid>
</Window>
