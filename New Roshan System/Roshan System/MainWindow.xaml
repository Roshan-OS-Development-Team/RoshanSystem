<Window x:Class="Roshan_System.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Roshan_System"
        Title="Roshan System" Width="1200" Height="800">

    <Grid>
        <Image x:Name="BackgroundImage" Source="/background2.png" Stretch="UniformToFill"/>
        <Rectangle HorizontalAlignment="Left" Height="70" Margin="0,690,0,0" Stroke="Black" VerticalAlignment="Top" Width="1180" Fill="Black"/>
        <Button Content="Button" HorizontalAlignment="Left" Margin="10,690,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.543" Height="70" Width="70" Foreground="{x:Null}">
            <Button.Background>
                <ImageBrush ImageSource="/startmenu.png"/>
            </Button.Background>

        </Button>
        <Button Content="Button" HorizontalAlignment="Left" Margin="80,690,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.517,0.603" Height="70" Width="50" Foreground="{x:Null}" Click="Open_Notepad">
            <Button.Background>
                <ImageBrush ImageSource="/notepad.png"/>
            </Button.Background>
        </Button>
        <Button Content="Button" HorizontalAlignment="Left" Margin="130,690,0,0" VerticalAlignment="Top" Height="70" Width="50" Foreground="{x:Null}" Click="Open_Calculator">
            <Button.Background>
                <ImageBrush ImageSource="/calculator.png"/>
            </Button.Background>
        </Button>
        <Button Content="Button" HorizontalAlignment="Left" Margin="185,690,0,0" VerticalAlignment="Top" Height="70" Width="70" Click="Shutdown" Foreground="{x:Null}">
            <Button.Background>
                <ImageBrush ImageSource="/closeicon.png"/>
            </Button.Background>
        </Button>

    </Grid>
</Window>