<Window x:Class="Roshan_System.Pong"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pong" Height="400" Width="610"
        Icon="/Pong.png"
        Focusable="True"
        KeyDown="Window_KeyDown" KeyUp="Window_KeyUp">
    <Canvas Name="GameCanvas" Background="Black">
        <!-- Player Paddle -->
        <Rectangle Name="PlayerPaddle" Width="10" Height="80" Fill="White" Canvas.Left="10" Canvas.Top="150"/>
        <!-- Computer Paddle -->
        <Rectangle Name="ComputerPaddle" Width="10" Height="80" Fill="White" Canvas.Left="580" Canvas.Top="150"/>
        <!-- Ball -->
        <Ellipse Name="Ball" Width="15" Height="15" Fill="White" Canvas.Left="292.5" Canvas.Top="192.5"/>
        <!-- Scores -->
        <TextBlock Name="PlayerScoreText" Text="0" FontSize="24" Foreground="White" Canvas.Left="200" Canvas.Top="10"/>
        <TextBlock Name="ComputerScoreText" Text="0" FontSize="24" Foreground="White" Canvas.Left="380" Canvas.Top="10"/>
    </Canvas>
</Window>